local function abrirDropdown(caixaTexto, frameLista, tabelaDados)
	if not (caixaTexto and frameLista) then return end
	
	frameLista.Visible = not frameLista.Visible
	
	for _, v in pairs(frameLista:GetChildren()) do
		if v:IsA("GuiObject") and v.ClassName ~= "UIListLayout" then
			v:Destroy()
		end
	end
	
	if frameLista.Visible then
		for _, v64 in pairs(tabelaDados) do
			local btn = templateButton and templateButton:Clone() or Instance.new("TextButton")
			
			if not templateButton then
				btn.Size = UDim2.new(1, 0, 0, 25)
				btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
				btn.TextColor3 = Color3.new(1, 1, 1)
				btn.TextSize = 14
			end
			
			btn.Name = v64.Name
			btn.Text = v64.Name
			btn.Parent = frameLista
			btn.Visible = true
			
			btn.MouseButton1Click:Connect(function()
				caixaTexto.Text = btn.Text
				frameLista.Visible = false
				
				for _, v66 in pairs(frameLista:GetChildren()) do
					if v66:IsA("GuiObject") and v66.ClassName ~= "UIListLayout" then
						v66:Destroy()
					end
				end
			end)
		end
	end
end

local function registrar(tabela, nome)
	for _, v in pairs(tabela) do
		if v.Name == nome then return end
	end
	table.insert(tabela, {["Name"] = nome})
end

Remotes.ConferirTsunamiNoAdmin.OnClientEvent:Connect(function(p) registrar(dados.Tsunami, p) end)
Remotes.ConferirEventosNoAdmin.OnClientEvent:Connect(function(p) registrar(dados.Eventos, p) end)
